# 6. Amazon Store: Recommendation Features


import json


# load the data
def load_data(file_name):
    with open(file_name, "r") as f:
        data = json.load(f)
    return data


data = load_data("store_data.json")
print(data)


# clean & structure the data
def clean_data(data):
    text_to_num = {"one": 1, "two": 2, "three": 3, "four": 4, "five": 5}
    cleaned_data = []
    unique_users = set()
    for user in data:
        # clean ratings
        row_rating = str(user["rating"]).strip().lower()
        if row_rating in text_to_num:
            row_rating = text_to_num[row_rating]
        user["rating"] =  row_rating

        # handle missing values
        row_age = user.get("age")
        if row_age == None:
            user["age"] = None

        #Deduplication
        if(user["name"].strip() in unique_users):
            continue
        unique_users.add(user["name"])
        cleaned_data.append(user)
    return cleaned_data


clean_data(data)


def meaningful_insights(data):
    sum = 0
    poor_rate = 0
    count = 0
    for user in data:
        sum += float(user["rating"])
        count += 1
        if float(user["rating"]) < 3:
            poor_rate += 1
    print(f"Average Rating: {round(sum/count, 2)}")
    print(f"With Poor Rating: {round((poor_rate/count)*100, 2)}%")


meaningful_insights(clean_data(data))


def recommendation_feature(data):
    for user in data:
        if user["rating"] >= 4:
            print(f"{user["name"]} purchase the same product again.")
        else:
            print(f"{user["name"]} purchasethe different product again.")



