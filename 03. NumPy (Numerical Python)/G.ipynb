   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[[ 1  3]\n",
      " [ 5  7]\n",
      " [ 9 11]] (3, 2)\n",
      "[[ 1  3  5]\n",
      " [ 7  9 11]] (2, 3)\n",
      "[ 1  3  5  7  9 11]\n"
     ]
    }
   ],
   "source": [
    "arr = np.array(([1, 3], [5, 7], [9, 11]))\n",
    "\n",
    "print(arr, arr.shape)\n",
    "\n",
    "print(arr.reshape(2, 3), arr.reshape(2, 3).shape)\n",
    "\n",
    "print(arr.flatten())"
   ]
  }
